# ========================
# AgriDetect-AI .gitignore
# Full-stack: Python Flask + React Vite
# ========================

# ----- Python / Backend -----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
*.egg

# Flask / SQLite
*.db
*.db-journal

# Logs & debug output
*.log
server_output*.txt
inspect_*output*.txt

# Uploaded user content (recreated at runtime)
backend/uploads/

# ML model weights (too large for Git)
backend/models/*.h5
backend/models/*.keras
backend/models/*.pt
backend/models/*.pth

# ----- Node / Frontend -----
node_modules/
dist/
build/
*.tsbuildinfo

# ----- Environment variables -----
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# ----- IDE / OS -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
